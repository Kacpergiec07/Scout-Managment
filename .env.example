# Twitter API Configuration (Optional)
# Get your bearer token from: https://developer.twitter.com/en/portal/dashboard
# If not configured, the system will use RSS feeds and fallback to mock data
NEXT_PUBLIC_TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Alternative: RSS Feed Configuration
# The system automatically uses public RSS feeds from football portals
# No additional configuration needed for RSS feeds

# CORS Configuration (if needed for RSS feeds)
# Some RSS feeds might require CORS proxy
NEXT_PUBLIC_CORS_PROXY_URL=https://cors-anywhere.herokuapp.com/

# Development Settings
NEXT_PUBLIC_ENABLE_MOCK_DATA=true
NEXT_PUBLIC_NEWS_REFRESH_INTERVAL=600000 # 10 minutes in milliseconds
